# Database
DATABASE_URL="postgresql://music:music@localhost:5432/music_universe"

# Filesystem
MUSIC_LIBRARY_PATH="/srv/music"

# YT (binary paths — used in Phase 2+)
YT_DLP_PATH="/usr/local/bin/yt-dlp"
FFMPEG_PATH="/usr/local/bin/ffmpeg"

# MusicBrainz etiquette (used in Phase 4)
MUSICBRAINZ_USER_AGENT="MusicUniverse/1.0 ( your-email@example.com )"

# Auth
# Generate hash:   pnpm exec node -e "import('bcryptjs').then(b => console.log(b.default.hashSync('your-password', 12)))"
APP_PASSWORD_HASH="$2b$12$replace-with-real-bcrypt-hash"

# Generate secret: pnpm exec node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET="replace-with-32-plus-random-bytes-hex"
