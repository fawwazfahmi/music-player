generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== Core music entities =====

model Artist {
  id              String    @id @default(cuid())
  name            String    @unique
  sortName        String?
  bio             String?
  photoUrl        String?
  discoveredAt    DateTime?
  mbid            String?   @unique
  metadataFetched DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  albums       Album[]
  tracks       Track[]              @relation("TrackPrimaryArtist")
  trackArtists TrackArtist[]
  genres       ArtistGenre[]
  tags         ArtistTag[]
  externalIds  ExternalIdentifier[] @relation("ArtistIds")
  favoritedBy  FavoriteArtist[]
  relatedFrom  RelatedArtist[]      @relation("ArtistFrom")
  relatedTo    RelatedArtist[]      @relation("ArtistTo")

  @@index([name])
  @@index([sortName])
}

model Album {
  id              String    @id @default(cuid())
  title           String
  sortTitle       String?
  releaseDate     DateTime?
  coverArtPath    String?
  coverArtHash    String?
  totalDuration   Int?
  artistId        String
  mbid            String?   @unique
  metadataFetched DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  artist      Artist               @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tracks      Track[]
  genres      AlbumGenre[]
  tags        AlbumTag[]
  externalIds ExternalIdentifier[] @relation("AlbumIds")
  favoritedBy FavoriteAlbum[]

  @@unique([artistId, title])
  @@index([title])
  @@index([releaseDate])
}

model Track {
  id          String  @id @default(cuid())
  title       String
  sortTitle   String?
  duration    Int
  trackNumber Int?
  discNumber  Int?

  filePath   String? @unique
  fileSize   BigInt?
  fileFormat String?
  bitrate    Int?
  sha256     String? @unique

  source    TrackSource @default(LOCAL_SCAN)
  ytVideoId String?     @unique
  playable  Boolean     @default(true)

  albumId         String?
  primaryArtistId String
  mbid            String?   @unique
  metadataFetched DateTime?
  discoveredAt    DateTime?

  // Lyrics (LRCLIB or Whisper-transcribed)
  lyricsSynced  String?
  lyricsPlain   String?
  lyricsSource  LyricsSource?
  lyricsFetched DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  album             Album?               @relation(fields: [albumId], references: [id], onDelete: SetNull)
  primaryArtist     Artist               @relation("TrackPrimaryArtist", fields: [primaryArtistId], references: [id])
  additionalArtists TrackArtist[]
  tags              TrackTag[]
  notes             SongNote[]
  history           ListeningHistory[]
  playlistEntries   PlaylistTrack[]
  favoritedBy       FavoriteTrack[]
  externalIds       ExternalIdentifier[] @relation("TrackIds")
  ytCache           YtCacheEntry?

  @@index([title])
  @@index([albumId, trackNumber])
  @@index([primaryArtistId])
}

enum TrackSource {
  LOCAL_SCAN
  YT_CACHED
  YT_STREAMING
  UPLOAD
}

model TrackArtist {
  trackId  String
  artistId String
  role     String?
  track    Track   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artist   Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([trackId, artistId])
}

// ===== Genres & Tags =====

model Genre {
  id      String        @id @default(cuid())
  name    String        @unique
  mbid    String?       @unique
  artists ArtistGenre[]
  albums  AlbumGenre[]
}

model ArtistGenre {
  artistId String
  genreId  String
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  genre    Genre  @relation(fields: [genreId], references: [id])

  @@id([artistId, genreId])
}

model AlbumGenre {
  albumId String
  genreId String
  album   Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  genre   Genre  @relation(fields: [genreId], references: [id])

  @@id([albumId, genreId])
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  color   String?
  tracks  TrackTag[]
  artists ArtistTag[]
  albums  AlbumTag[]
}

model TrackTag {
  trackId String
  tagId   String
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id])

  @@id([trackId, tagId])
}

model ArtistTag {
  artistId String
  tagId    String
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id])

  @@id([artistId, tagId])
}

model AlbumTag {
  albumId String
  tagId   String
  album   Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id])

  @@id([albumId, tagId])
}

// ===== Memory & personal data =====

model SongNote {
  id        String   @id @default(cuid())
  trackId   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([trackId, createdAt])
}

model FavoriteTrack {
  trackId     String   @id
  favoritedAt DateTime @default(now())
  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model FavoriteAlbum {
  albumId     String   @id
  favoritedAt DateTime @default(now())
  album       Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
}

model FavoriteArtist {
  artistId    String   @id
  favoritedAt DateTime @default(now())
  artist      Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
}

// ===== Playlists =====

model Playlist {
  id             String          @id @default(cuid())
  name           String
  description    String?
  coverImagePath String?
  position       Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tracks         PlaylistTrack[]
}

model PlaylistTrack {
  playlistId String
  trackId    String
  position   Int
  addedAt    DateTime @default(now())
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([playlistId, trackId])
  @@index([playlistId, position])
}

// ===== Listening history =====

model ListeningHistory {
  id               String         @id @default(cuid())
  trackId          String
  playedAt         DateTime       @default(now())
  durationListened Int
  completed        Boolean        @default(false)
  source           PlaybackSource
  track            Track          @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([playedAt])
  @@index([trackId, playedAt])
}

enum PlaybackSource {
  LOCAL_FILE
  YT_STREAM
  YT_CACHED
}

// ===== Artist relationships =====

model RelatedArtist {
  fromArtistId String
  toArtistId   String
  similarity   Float?
  source       String
  fromArtist   Artist @relation("ArtistFrom", fields: [fromArtistId], references: [id], onDelete: Cascade)
  toArtist     Artist @relation("ArtistTo", fields: [toArtistId], references: [id], onDelete: Cascade)

  @@id([fromArtistId, toArtistId, source])
}

// ===== Metadata caching =====

model ExternalIdentifier {
  id         String             @id @default(cuid())
  entityType ExternalEntityType
  source     String
  externalId String
  artistId   String?
  albumId    String?
  trackId    String?
  artist     Artist?            @relation("ArtistIds", fields: [artistId], references: [id], onDelete: Cascade)
  album      Album?             @relation("AlbumIds", fields: [albumId], references: [id], onDelete: Cascade)
  track      Track?             @relation("TrackIds", fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([source, externalId, entityType])
  @@index([artistId])
  @@index([albumId])
  @@index([trackId])
}

enum ExternalEntityType {
  ARTIST
  ALBUM
  TRACK
}

// ===== YouTube cache =====

model YtCacheEntry {
  ytVideoId       String        @id
  trackId         String?       @unique
  status          YtCacheStatus
  downloadedBytes BigInt        @default(0)
  totalBytes      BigInt?
  localFilePath   String?
  errorMessage    String?
  attempts        Int           @default(0)
  createdAt       DateTime      @default(now())
  completedAt     DateTime?
  track           Track?        @relation(fields: [trackId], references: [id], onDelete: SetNull)
}

enum YtCacheStatus {
  PENDING
  DOWNLOADING
  READY
  FAILED
}

// ===== Metadata enrichment jobs =====

model MetadataJob {
  id          String             @id @default(cuid())
  entityType  ExternalEntityType
  artistId    String?
  albumId     String?
  trackId     String?
  status      JobStatus
  attempts    Int                @default(0)
  lastError   String?
  createdAt   DateTime           @default(now())
  completedAt DateTime?

  @@index([status, createdAt])
}

enum JobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

// ===== Settings =====

model AppSetting {
  key   String @id
  value String
}
